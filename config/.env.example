# stt 플러그인 설정 — 복사해서 config/.env 로 쓰고 값 채우기 (config/.env 는 커밋 금지)

# --- clovanote 소스 (네이버 클로바노트) ---
# 네이버 로그인 크리덴셜 (login.py --auto/--seed 용)
NAVER_ID=
NAVER_PW=

# 노트 마크다운 저장 경로 (각자 vault 로 지정). 기본: ~/.clovanote/notes
CLOVANOTE_OUT=~/clovanote-notes

# 세션·프로필·가드상태 저장 홈 (선택, 기본 ~/.clovanote — gitignore 밖에 두는 걸 권장)
# CLOVANOTE_HOME=~/.clovanote
